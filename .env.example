# Application
JWT_SECRET=change-me-in-production
PORT=5000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# YouTube channel handle is @rccgtlp1
# Get numeric Channel ID: youtube.com/@rccgtlp1 → About → Share → Copy Channel ID
YOUTUBE_CHANNEL_ID=

# Stripe — get from dashboard.stripe.com → Developers → API keys
# Use test key (sk_test_...) during development
STRIPE_SECRET_KEY=

# Web Push VAPID keys — generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lighthouseparish.org
